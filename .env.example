PORT=4000
HOST=0.0.0.0
APP_NAME="CryptoBot Prime"
AUTH_HASH_SECRET=change-this-secret
OTP_TTL_MINUTES=10
RESET_TOKEN_TTL_MINUTES=15
SESSION_TTL_DAYS=30
AUTH_DATA_DIR=./server/data
AUTH_DATA_DIR_FALLBACK=/tmp/cryptobot2-auth-data
SERVE_STATIC=false

# For Brevo SMTP testing:
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=your-brevo-smtp-login-email
# SMTP_PASS=your-brevo-smtp-key
# SMTP_FROM=CryptoBot Prime <your-verified-sender@example.com>
# DEV_RETURN_OTP_IN_RESPONSE=true
# Important:
# - SMTP_PASS must be a Brevo SMTP key, not your Brevo account password or API key.
# - SMTP_FROM must be a verified sender email or a sender from an authenticated domain.

# For Gmail app-password testing:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=yourgmail@gmail.com
# SMTP_PASS=your-16-character-app-password
# SMTP_FROM=CryptoBot Prime <yourgmail@gmail.com>

# Browser web app can use localhost during local development.
# If backend is in the same Vercel project (using api/auth route files), leave VITE_API_BASE_URL empty.
# If backend is hosted separately, set VITE_API_BASE_URL to that public HTTPS backend URL.
# By default, deployed web builds use same-origin `/api` only.
# Set this to true only if you intentionally want external API fallback in web builds.
# VITE_ALLOW_EXTERNAL_API_FALLBACK=true
# Mobile app should use your PC/LAN IP (same Wi-Fi), e.g. http://192.168.0.121:4000
VITE_API_BASE_URL=http://localhost:4000

# Blob persistence (primarily for Vercel serverless environments).
# If Blob quota is exhausted, you can hard-disable with:
# BLOB_SYNC_DISABLED=true
# By default quota/permission failures auto-disable sync for the running instance:
# BLOB_SYNC_DISABLE_ON_FAILURE=true
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_token
# BLOB_PERSISTENCE_REQUIRED=false
# BLOB_SYNC_MIN_INTERVAL_MS=1500

# Google sign-in:
# VITE_GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_IDS=optional-extra-client-id.apps.googleusercontent.com
# VITE_PUBLIC_AUTH_BASE_URL=https://your-public-ngrok-or-cloudflare-url
# VITE_NATIVE_AUTH_CALLBACK_URL=cryptobotprime://auth-callback
